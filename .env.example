# Copia este archivo a `.env` (en la raíz del repo o en server/) y ajusta los
# valores. El servidor lo lee al arrancar; las variables del entorno real
# tienen prioridad sobre las del archivo. `.env` está en .gitignore: nunca se
# sube al repositorio (aquí van claves API).

# Correos con rol de administrador (separados por coma).
ADB_ADMIN_EMAIL=admin@example.com

# Puerto/host de la API (por defecto 8731 / 127.0.0.1).
#PORT=8731
#HOST=127.0.0.1

# URL pública para los enlaces de los correos de confirmación.
#BASE_URL=http://localhost:5173

# Envío real de correo (sin SMTP_HOST, los correos se imprimen en consola).
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=

# Jugadores LLM (las claves viven solo en el servidor).
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#DEEPSEEK_API_KEY=
#OPENROUTER_API_KEY=
#OPENROUTER_MODELS=qwen/qwen3-32b,x-ai/grok-4
